    "/v1/feeds/{feed.id}": {
      "patch": {
        "summary": "Update a feed",
        "operationId": "FeedService_UpdateFeed",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Feed"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "feed.id",
            "description": "Unique feed identifier (ULID). Output only on create.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "feed",
            "description": "feed with updated fields. feed.id must be set.",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "description": "Human-readable feed title. Auto-populated from the feed if omitted."
                },
                "xml_url": {
                  "type": "string",
                  "description": "xml_url is the RSS/Atom feed URL. Required."
                },
                "html_url": {
                  "type": "string",
                  "description": "html_url is the feed's website homepage."
                },
                "folder_id": {
                  "type": "string",
                  "description": "folder_id is empty if the feed is uncategorized."
                },
                "description": {
                  "type": "string"
                },
                "icon_url": {
                  "type": "string"
                },
                "refresh_interval_seconds": {
                  "type": "integer",
                  "format": "int32",
                  "description": "refresh_interval_seconds overrides the global refresh interval. Minimum 60."
                },
                "last_fetched_time": {
                  "type": "string",
                  "format": "date-time",
                  "description": "last_fetched_time is the last successful fetch time. Output only.",
                  "readOnly": true
                },
                "unread_count": {
                  "type": "integer",
                  "format": "int32",
                  "description": "unread_count is the number of unread articles. Output only.",
                  "readOnly": true
                },
                "last_error": {
                  "type": "string",
                  "description": "last_error is populated when the last fetch failed. Output only.",
                  "readOnly": true
                },
                "error_count": {
                  "type": "integer",
                  "format": "int32",
                  "description": "error_count is the number of consecutive fetch failures. Output only.",
                  "readOnly": true
                },
                "is_favorite": {
                  "type": "boolean",
                  "description": "is_favorite marks this feed as a favorite (shown in the Favorites section)."
                },
                "create_time": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true
                },
                "update_time": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true
                }
              },
              "title": "feed with updated fields. feed.id must be set.",
              "required": [
                "xml_url"
              ]
            }
          }
        ],
        "tags": [
          "Feeds"
        ]
      }
    },
