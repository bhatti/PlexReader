  "paths": {
    "/v1/articles": {
      "get": {
        "summary": "List articles",
        "description": "Returns articles filtered by feed, folder, read state, or full-text query. Default shows unread articles newest first.",
        "operationId": "ArticleService_ListArticles",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListArticlesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "feed_id",
            "description": "feed_id filters to a specific feed. Mutually exclusive with folder_id.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "folder_id",
            "description": "folder_id filters to all feeds in a folder. Mutually exclusive with feed_id.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "unread_only",
            "description": "unread_only, when true, returns only unread articles (default behaviour).",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "starred_only",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "saved_for_later_only",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "today_only",
            "description": "today_only restricts to articles published in the last 24 hours.",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "query",
            "description": "query triggers full-text search across title, content, and summary.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "sort_order",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "SORT_ORDER_UNSPECIFIED",
              "SORT_ORDER_NEWEST_FIRST",
              "SORT_ORDER_OLDEST_FIRST"
            ],
            "default": "SORT_ORDER_UNSPECIFIED"
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "page_token",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "read_only",
            "description": "read_only returns only articles individually opened by the user (read_at IS NOT NULL).\nUsed by the Recently Read screen. Does not include articles bulk-marked via MarkAllRead.",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "Articles"
        ]
      }
    },
