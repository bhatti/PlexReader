  "definitions": {
    "ArticleServiceMarkAsReadBody": {
      "type": "object"
    },
    "ArticleServiceMarkAsUnreadBody": {
      "type": "object"
    },
    "ArticleServiceSaveForLaterBody": {
      "type": "object",
      "properties": {
        "saved": {
          "type": "boolean",
          "description": "saved=true to save for later, false to remove."
        }
      }
    },
    "ArticleServiceStarArticleBody": {
      "type": "object",
      "properties": {
        "starred": {
          "type": "boolean",
          "description": "starred=true to star, false to unstar."
        }
      }
    },
    "FeedServiceRefreshFeedBody": {
      "type": "object"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1Article": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique article identifier (ULID). Output only.",
          "readOnly": true
        },
        "feed_id": {
          "type": "string",
          "description": "feed_id is the parent feed. Output only.",
          "readOnly": true
        },
        "title": {
          "type": "string"
        },
        "link": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "description": "content is the full HTML body of the article."
        },
        "summary": {
          "type": "string",
          "description": "summary is a plain-text excerpt (~300 chars) for list views."
        },
        "author": {
          "type": "string"
        },
        "published_time": {
          "type": "string",
          "format": "date-time"
        },
        "guid": {
          "type": "string",
          "description": "guid is the feed-provided unique identifier used for deduplication.",
          "readOnly": true
        },
        "thumbnail_url": {
          "type": "string"
        },
        "is_read": {
          "type": "boolean"
        },
        "is_starred": {
          "type": "boolean"
        },
        "is_saved_for_later": {
          "type": "boolean"
        },
        "read_at": {
          "type": "string",
          "format": "date-time",
          "description": "read_at is set when is_read transitions to true. Output only.",
          "readOnly": true
        },
        "create_time": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        }
      },
      "description": "Article represents a single item fetched from an RSS/Atom feed."
    },
    "v1ExportOPMLResponse": {
      "type": "object",
      "properties": {
        "opml_content": {
          "type": "string",
          "format": "byte",
          "description": "opml_content is the OPML 1.0 XML export bytes."
        }
      }
    },
    "v1Feed": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique feed identifier (ULID). Output only on create.",
          "readOnly": true
        },
        "title": {
          "type": "string",
          "description": "Human-readable feed title. Auto-populated from the feed if omitted."
        },
        "xml_url": {
          "type": "string",
          "description": "xml_url is the RSS/Atom feed URL. Required."
        },
        "html_url": {
          "type": "string",
          "description": "html_url is the feed's website homepage."
        },
        "folder_id": {
          "type": "string",
          "description": "folder_id is empty if the feed is uncategorized."
        },
        "description": {
          "type": "string"
        },
        "icon_url": {
          "type": "string"
        },
        "refresh_interval_seconds": {
          "type": "integer",
          "format": "int32",
          "description": "refresh_interval_seconds overrides the global refresh interval. Minimum 60."
        },
        "last_fetched_time": {
          "type": "string",
          "format": "date-time",
          "description": "last_fetched_time is the last successful fetch time. Output only.",
          "readOnly": true
        },
        "unread_count": {
          "type": "integer",
          "format": "int32",
          "description": "unread_count is the number of unread articles. Output only.",
          "readOnly": true
        },
        "last_error": {
          "type": "string",
          "description": "last_error is populated when the last fetch failed. Output only.",
          "readOnly": true
        },
        "error_count": {
          "type": "integer",
          "format": "int32",
          "description": "error_count is the number of consecutive fetch failures. Output only.",
          "readOnly": true
        },
        "is_favorite": {
          "type": "boolean",
          "description": "is_favorite marks this feed as a favorite (shown in the Favorites section)."
        },
        "create_time": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        },
        "update_time": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        }
      },
      "description": "Feed represents a subscribed RSS/Atom feed source.",
      "required": [
        "xml_url"
      ]
    },
    "v1Folder": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique folder identifier (ULID). Output only on create.",
          "readOnly": true
        },
        "name": {
          "type": "string",
          "description": "Human-readable folder name. Required."
        },
        "parent_id": {
          "type": "string",
          "description": "parent_id is empty for root-level folders. Reserved for nested folders."
        },
        "position": {
          "type": "integer",
          "format": "int32",
          "description": "position controls sidebar display order (ascending)."
        },
        "unread_count": {
          "type": "integer",
          "format": "int32",
          "description": "unread_count is the total unread articles across all feeds in this folder. Output only.",
          "readOnly": true
        },
        "create_time": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        },
        "update_time": {
          "type": "string",
          "format": "date-time",
          "readOnly": true
        }
      },
      "description": "Folder organizes feeds into named groups.",
      "required": [
        "name"
      ]
    },
    "v1ImportOPMLRequest": {
      "type": "object",
      "properties": {
        "opml_content": {
          "type": "string",
          "format": "byte",
          "description": "opml_content is the raw OPML XML bytes (UTF-8 encoded)."
        }
      },
      "required": [
        "opml_content"
      ]
    },
    "v1ImportOPMLResponse": {
      "type": "object",
      "properties": {
        "feeds_created": {
          "type": "integer",
          "format": "int32",
          "description": "feeds_created is the number of new feeds added."
        },
        "folders_created": {
          "type": "integer",
          "format": "int32",
          "description": "folders_created is the number of new folders added."
        },
        "feeds_skipped": {
          "type": "integer",
          "format": "int32",
          "description": "feeds_skipped is the number of feeds that already existed."
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "errors lists any non-fatal errors encountered during import."
        }
      }
    },
    "v1ListArticlesResponse": {
      "type": "object",
      "properties": {
        "articles": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Article"
          }
        },
        "next_page_token": {
          "type": "string"
        },
        "total_count": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1ListFeedsResponse": {
      "type": "object",
      "properties": {
        "feeds": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Feed"
          }
        },
        "next_page_token": {
          "type": "string"
        }
      }
    },
    "v1ListFoldersResponse": {
      "type": "object",
      "properties": {
        "folders": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Folder"
          }
        }
      }
    },
    "v1MarkAllAsReadRequest": {
      "type": "object",
      "properties": {
        "feed_id": {
          "type": "string",
          "description": "feed_id marks all unread articles in a specific feed."
        },
        "folder_id": {
          "type": "string",
          "description": "folder_id marks all unread articles in a folder."
        },
        "all": {
          "type": "boolean",
          "description": "all marks every unread article across all feeds."
        },
        "article_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "article_ids marks a specific selection. Takes priority over scope if non-empty."
        },
        "before_time": {
          "type": "string",
          "format": "date-time",
          "description": "before_time only marks articles published before this time (optional filter)."
        }
      }
    },
    "v1MarkAllAsReadResponse": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "format": "int32",
          "description": "count is the number of articles marked as read."
        }
      }
    },
    "v1ReorderFoldersRequest": {
      "type": "object",
      "properties": {
        "folder_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "folder_ids in the desired display order (ascending position)."
        }
      },
      "required": [
        "folder_ids"
      ]
    },
    "v1ReorderFoldersResponse": {
      "type": "object",
      "properties": {
        "folders": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Folder"
          }
        }
      }
    },
    "v1SortOrder": {
      "type": "string",
      "enum": [
        "SORT_ORDER_UNSPECIFIED",
        "SORT_ORDER_NEWEST_FIRST",
        "SORT_ORDER_OLDEST_FIRST"
      ],
      "default": "SORT_ORDER_UNSPECIFIED",
      "description": "SortOrder controls article sort direction."
    },
    "v1StartPage": {
      "type": "string",
      "enum": [
        "START_PAGE_UNSPECIFIED",
        "START_PAGE_TODAY",
        "START_PAGE_FIRST_FOLDER",
        "START_PAGE_ALL"
      ],
      "default": "START_PAGE_UNSPECIFIED",
      "description": "StartPage controls which page loads on app start."
    },
    "v1UserPreferences": {
      "type": "object",
      "properties": {
        "start_page": {
          "$ref": "#/definitions/v1StartPage",
          "description": "start_page controls which view loads on app start."
        },
        "default_view": {
          "$ref": "#/definitions/v1ViewMode",
          "description": "default_view controls the article list presentation."
        },
        "default_sort": {
          "$ref": "#/definitions/v1SortOrder",
          "description": "default_sort controls article sort order."
        },
        "hide_read_articles": {
          "type": "boolean",
          "description": "hide_read_articles, when true (default), hides already-read articles from feed lists."
        },
        "global_refresh_interval_seconds": {
          "type": "integer",
          "format": "int32",
          "description": "global_refresh_interval_seconds applies to feeds without a custom interval. Min 60."
        },
        "retention_days": {
          "type": "integer",
          "format": "int32",
          "description": "retention_days: read articles older than this are auto-deleted. 0 = keep forever."
        },
        "theme": {
          "type": "string",
          "description": "theme is reserved for future theme support. Default: \"dark\"."
        }
      },
      "description": "UserPreferences holds global reader settings (single user, persisted)."
    },
    "v1ViewMode": {
      "type": "string",
      "enum": [
        "VIEW_MODE_UNSPECIFIED",
        "VIEW_MODE_TITLE_ONLY",
        "VIEW_MODE_MAGAZINE",
        "VIEW_MODE_CARDS",
        "VIEW_MODE_ARTICLE"
      ],
      "default": "VIEW_MODE_UNSPECIFIED",
      "description": "ViewMode controls article list presentation."
    }
  }
}
