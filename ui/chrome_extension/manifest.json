{
  "manifest_version": 3,
  "name": "PlexReader",
  "version": "1.0.0",
  "description": "Self-hosted RSS reader",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*/*"
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
